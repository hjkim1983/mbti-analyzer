# 복사 후 .env 로 저장하고 값 채우기
# 배포 도메인(메타데이터 절대 URL·OG 일치용). 로컬은 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_GEMINI_API_KEY=

# Gemini 모델 (서버 전용). 2.5-flash 과부하 시 예: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# 503·UNAVAILABLE 시 재시도 (선택, 기본 5회·최대 8회 / 초기 대기 ~1.2s)
# GEMINI_MAX_RETRIES=5
# GEMINI_RETRY_BASE_MS=1200

# Supabase — URL과 anon 키는 동일 프로젝트(Settings → API)에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=

# 로컬 전용: true 이면 결제 없이 분석, API 요청/응답 콘솔 로그, Gemini 오류 시 상세 JSON 표시
# (npm run dev + NODE_ENV=development 일 때만 서버·클라이언트에서 적용됩니다)
DEV_MODE=
